{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "recursio",
  "version": "0.1.0",
  "identifier": "com.recursio.recursio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "recursio",
        "minWidth": 1000,
        "minHeight": 600,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/llamacpp/llama-server"
    ],
    "resources": {
      "binaries/llamacpp/*.dll": "./"
    }
  }
}